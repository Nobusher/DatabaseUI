<Window x:Class="DBInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBInterface"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        
        <TextBlock Grid.ColumnSpan="3" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" Width="452" TextAlignment="Center" Height="141" Text="Здравствуй РАБотник с базами данных. Если тебе нужно заполнить очередные таблицы, то выбери какую таблицу ты хочешь заполнять. Если нет, закрой это окно от греха подальше..." FontSize="22" FontFamily="Arial" FontWeight="Bold"/>
        <Button Grid.Column="2" Grid.Row="2" HorizontalAlignment="Left" Margin="10" Content="В Покупателя" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"  Click="Button_Click_1"/>
        <Button Grid.Column="1" Grid.Row="1" HorizontalAlignment="Right" Margin="10" Content="В Категории" VerticalAlignment="Top"  FontWeight="Bold" FontSize="16"  Click="Button_Click"/>
        <Button Grid.Column="0" Grid.Row="1" HorizontalAlignment="Right" Margin="10" Content="В Продукты" VerticalAlignment="Top"  FontWeight="Bold" FontSize="16"  Click="Button_Click_2"/>
        <Button Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" Margin="10" Content="В Заказы" VerticalAlignment="Top"  FontWeight="Bold" FontSize="18"  Click="Button_Click_3"/>
        <Button Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left" Margin="10" Content="В Корзину" VerticalAlignment="Top"  FontWeight="Bold" FontSize="18"  Click="Button_Click_4"/>
        <Button Grid.Column="2" Grid.Row="2" HorizontalAlignment="Right" Margin="10" Content="Выйти" VerticalAlignment="Top"  FontWeight="Bold" FontSize="18"  Click="Button_Click_4"/>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        
            
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
    </Grid>
</Window>
