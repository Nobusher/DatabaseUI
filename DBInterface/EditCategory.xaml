<Window x:Class="DBInterface.EditCategory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBInterface"
        mc:Ignorable="d"
        Title="EditCategory" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <ListBox x:Name="Category_ListBox" Background="#FFD0D0D0" BorderBrush="Black" FontSize="20" FontWeight="Bold" SelectionChanged="ListBox_SelectionChanged"/>
        <TextBox x:Name="InputTextBox" Grid.Column="1" HorizontalAlignment="Center" Margin="0,309,0,0" TextWrapping="Wrap" Text="Введите категорию" VerticalAlignment="Top" Width="344" Height="36" Background="WhiteSmoke" BorderBrush="Black" FontSize="22" FontWeight="Bold"/>
        <Button Grid.Column="1" Content="Добавить" HorizontalAlignment="Left" Margin="48,370,0,0" VerticalAlignment="Top" Height="40" Width="113" FontWeight="Bold" FontSize="18" Click="Button_Click_1"/>
        <Button Grid.Column="1" Content="Удалить" HorizontalAlignment="Left" Margin="246,370,0,0" VerticalAlignment="Top" Height="40" Width="113" FontWeight="Bold" FontSize="20" Click="Button_Click"/>
        <Button Grid.Column="1" Content="Сохранить" HorizontalAlignment="Left" Margin="28,22,0,0" VerticalAlignment="Top" Height="40" Width="113" FontWeight="Bold" FontSize="20" Click="Button_Click_2"/>
        <Button Grid.Column="1" Content="Сохранить и выйти" HorizontalAlignment="Left" Margin="164,22,0,0" VerticalAlignment="Top" Height="40" Width="216" FontWeight="Bold" FontSize="20"/>
        <Button Grid.Column="1" Content="Выйти без сохранения" HorizontalAlignment="Center" Margin="0,80,0,0" VerticalAlignment="Top" Height="40" Width="304" FontWeight="Bold" FontSize="20"/>

    </Grid>
</Window>
